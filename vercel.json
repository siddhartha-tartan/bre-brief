{
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/generate.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
